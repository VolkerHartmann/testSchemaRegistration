{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "http://www.example.org/schema/json/simple_v2",
  "type": "object",
  "title": "Json schema for tests",
  "default": {},
  "required": [
    "title",
    "author"
  ],
  "properties": {
    "title": {
      "type": "string",
      "title": "Title",
      "description": "Title of article."
    },
    "author": {
      "type": "string",
      "title": "Author",
      "description": "Author of article"
    },
    "date": {
      "type": "string",
      "format": "date",
      "title": "Date",
      "description": "Publishing date of article"
    }
  }
  },
  "additionalProperties": false
}
